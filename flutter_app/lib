import 'package:flutter/material.dart';
import 'theme/app_theme.dart';
import 'screens/login_screen.dart';
import 'screens/dashboard_screen.dart';
import 'screens/control_screen.dart';
import 'screens/history_screen.dart';
import 'screens/settings_screen.dart';
import 'screens/activity_screen.dart';
import 'screens/profile_screen.dart';
import 'services/auth_service.dart';

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  
  final authService = AuthService();
  await authService.loadCurrentUser();
  final isLoggedIn = authService.isLoggedIn;
  
  runApp(SerreConnecteeApp(isLoggedIn: isLoggedIn));
}

class SerreConnecteeApp extends StatelessWidget {
  final bool isLoggedIn;
  
  const SerreConnecteeApp({super.key, required this.isLoggedIn});
  
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: '🌿 Bloomy',  // ✅ Changé
      debugShowCheckedModeBanner: false,
      theme: AppTheme.lightTheme,
      initialRoute: isLoggedIn ? '/dashboard' : '/login',
      routes: {
        '/login': (context) => const LoginScreen(),
        '/dashboard': (context) => const DashboardScreen(),
        '/control': (context) => const ControlScreen(),
        '/history': (context) => const HistoryScreen(),
        '/settings': (context) => const SettingsScreen(),
        '/activity': (context) => ActivityScreen(),
        '/profile': (context) => const ProfileScreen(),
      },
    );
  }
}

class AppNavigator {
  static void goToDashboard(BuildContext context) => Navigator.pushReplacementNamed(context, '/dashboard');
  static void goToLogin(BuildContext context) => Navigator.pushReplacementNamed(context, '/login');
  static void pop(BuildContext context) => Navigator.pop(context);
  static void goTo(BuildContext context, String route) => Navigator.pushNamed(context, route);
}
